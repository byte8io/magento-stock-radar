<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="byte8_stock_radar_dispatch" instance="Byte8\StockRadar\Cron\DispatchSender" method="execute">
            <schedule>* * * * *</schedule>
        </job>
        <job name="byte8_stock_radar_expire" instance="Byte8\StockRadar\Cron\ExpireSubscriptions" method="execute">
            <schedule>15 3 * * *</schedule>
        </job>
    </group>
</config>
