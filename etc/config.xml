<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <byte8_stock_radar>
            <activation>
                <endpoint>https://api.byte8.io/graphql</endpoint>
                <timeout>5</timeout>
                <connect_timeout>2</connect_timeout>
            </activation>
            <general>
                <active>0</active>
            </general>
            <dispatch>
                <throttle_minutes>30</throttle_minutes>
                <expiry_days>90</expiry_days>
            </dispatch>
            <email>
                <sender>sales</sender>
                <template>byte8_stock_radar_email_template</template>
            </email>
            <admin_alert>
                <threshold>50</threshold>
                <bell_enabled>1</bell_enabled>
                <email_enabled>1</email_enabled>
                <email_sender>general</email_sender>
                <email_template>byte8_stock_radar_admin_alert_email_template</email_template>
            </admin_alert>
            <security>
                <rate_limit_enabled>1</rate_limit_enabled>
                <captcha_form_id>byte8_stock_radar_subscribe</captcha_form_id>
                <rate_limit_per_ip>5</rate_limit_per_ip>
                <rate_limit_per_email>3</rate_limit_per_email>
                <honeypot_enabled>1</honeypot_enabled>
                <hide_created_flag>1</hide_created_flag>
                <captcha_enabled>0</captcha_enabled>
                <double_optin_enabled>0</double_optin_enabled>
                <confirmation_email_template>byte8_stock_radar_security_confirmation_email_template</confirmation_email_template>
            </security>
        </byte8_stock_radar>
        <captcha translate="label">
            <frontend>
                <areas>
                    <byte8_stock_radar_subscribe>
                        <label>Stock Radar — back-in-stock subscribe</label>
                    </byte8_stock_radar_subscribe>
                </areas>
            </frontend>
        </captcha>
    </default>
</config>
