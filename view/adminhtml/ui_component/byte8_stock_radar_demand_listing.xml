<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">byte8_stock_radar_demand_listing.byte8_stock_radar_demand_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>byte8_stock_radar_demand_listing_columns</spinner>
        <deps>
            <dep>byte8_stock_radar_demand_listing.byte8_stock_radar_demand_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="byte8_stock_radar_demand_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Byte8_StockRadar::demand</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="byte8_stock_radar_demand_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>product_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="byte8_stock_radar_demand_listing_columns">
        <column name="subscriber_count">
            <settings>
                <filter>text</filter>
                <label translate="true">Pending subscribers</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="sku">
            <settings>
                <filter>text</filter>
                <label translate="true">SKU</label>
            </settings>
        </column>
        <column name="product_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Product</label>
            </settings>
        </column>
        <column name="product_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Product ID</label>
            </settings>
        </column>
        <column name="parent_product_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Parent ID</label>
            </settings>
        </column>
        <column name="store_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Store</label>
            </settings>
        </column>
        <column name="first_subscribed" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">First subscribed</label>
            </settings>
        </column>
        <column name="latest_subscribed" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Latest subscribed</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Byte8\StockRadar\Ui\Component\Listing\Column\Demand\Actions">
            <settings>
                <indexField>product_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
